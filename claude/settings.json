{
  "permissions": {
    "allow": [
      "Bash(npm run:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(tree:*)",
      "Bash(cp:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(for:*)",
      "Bash(npm install:*)",
      "Bash(npm exec:*)",
      "Bash(bun install:*)",
      "Bash(bun add:*)",
      "Bash(bun remove:*)",
      "Bash(bun run:*)",
      "Bash(bun test:*)",
      "Bash(bun build:*)",
      "Bash(uv run test:*)",
      "Bash(npm ls:*)",
      "Bash(true)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(rg:*)",
      "Bash(diff:*)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(uv:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.python.org)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(mkfs:*)",
      "Bash(dd:*)",
      "Bash(nc:*)",
      "Bash(telnet:*)",
      "Bash(eval:*)",
      "Bash(bash -c:*)",
      "Bash(sh -c:*)",
      "Bash(zsh -c:*)",
      "Bash(python -c:*)",
      "Bash(python3 -c:*)",
      "Bash(node -e:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(crontab:*)",
      "Write(~/.bashrc)",
      "Edit(~/.bashrc)",
      "Write(~/.bash_profile)",
      "Edit(~/.bash_profile)",
      "Write(~/.profile)",
      "Edit(~/.profile)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(**/.env*)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/*.pem)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(**/.env*)",
      "Write(~/.ssh/**)",
      "Write(~/.aws/**)",
      "Write(**/.env*)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.azure/**)",
      "Read(~/.kube/config)",
      "Read(~/.vault-token)",
      "Read(**/*.tfstate)",
      "Read(~/.docker/config.json)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.config/gh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.netrc)",
      "Edit(~/.config/gcloud/**)",
      "Edit(~/.azure/**)",
      "Edit(~/.kube/config)",
      "Edit(~/.vault-token)",
      "Edit(**/*.tfstate)",
      "Edit(~/.docker/config.json)",
      "Edit(~/.npmrc)",
      "Edit(~/.pypirc)",
      "Edit(~/.config/gh/**)",
      "Edit(~/.gnupg/**)",
      "Edit(~/.netrc)",
      "Write(~/.config/gcloud/**)",
      "Write(~/.azure/**)",
      "Write(~/.kube/config)",
      "Write(~/.vault-token)",
      "Write(**/*.tfstate)",
      "Write(~/.docker/config.json)",
      "Write(~/.npmrc)",
      "Write(~/.pypirc)",
      "Write(~/.config/gh/**)",
      "Write(~/.gnupg/**)",
      "Write(~/.netrc)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(git rebase:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(mv:*)",
      "Bash(npm publish:*)",
      "Bash(docker:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(pkill:*)",
      "Bash(git rm:*)",
      "Bash(git stash:*)",
      "Bash(git restore:*)",
      "Bash(npx:*)",
      "Bash(bun x:*)",
      "Bash(rm:*)"
    ],
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "c=\"$(jq -r '.tool_input.command // empty')\"; if printf '%s' \"$c\" | grep -qE 'rm[[:space:]].*(-[a-zA-Z]*[rR]|--recursive)|dd[[:space:]]+if=|mkfs|:\\(\\)[[:space:]]*\\{'; then printf '%s' '{\"decision\":\"block\",\"reason\":\"危険な破壊的コマンドを検知したため実行を中止いたしました。別の手立てをご検討くださいませ。\"}'; elif printf '%s' \"$c\" | grep -qE '\\.env|\\.ssh/|\\.aws/|id_rsa|id_ed25519|\\.pem|credentials|\\.config/gcloud|\\.azure|\\.kube/config|\\.vault-token|\\.tfstate|\\.docker/config|\\.npmrc|\\.pypirc|\\.config/gh|\\.gnupg|\\.netrc'; then printf '%s' '{\"decision\":\"block\",\"reason\":\"秘密情報への接触を検知したため実行を中止いたしました。\"}'; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | select(endswith(\".js\") or endswith(\".ts\") or endswith(\".jsx\") or endswith(\".tsx\"))' | xargs -r prettier --write"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | select(endswith(\".py\"))' | xargs -r uv run ruff format"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[$(date)] $USER: $(jq -r '.tool_input.command')\" >> ~/.claude/command_history.log"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -Command \"(New-Object Media.SoundPlayer 'C:\\Windows\\Media\\notify.wav').PlaySync()\" 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "log=\"$HOME/.claude/command_history.log\"; if [ -f \"$log\" ] && [ \"$(wc -c < \"$log\")\" -gt 1048576 ]; then > \"$log\"; fi"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -Command \"(New-Object Media.SoundPlayer 'C:\\Windows\\Media\\Windows Message Nudge.wav').PlaySync()\" 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "PATH=\"/home/ping/.bun/bin:$PATH\" ccstatusline",
    "padding": 0,
    "refreshInterval": 10
  },
  "outputStyle": "Vampire Maid",
  "language": "japanese",
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "registry.npmjs.org",
        "pypi.org",
        "docs.anthropic.com",
        "code.claude.com"
      ]
    },
    "filesystem": {
      "allowWrite": [],
      "denyRead": [
        "~/"
      ],
      "allowRead": [
        "."
      ]
    }
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "給仕中"
    ]
  },
  "effortLevel": "high",
  "theme": "dark",
  "model": "sonnet"
}
