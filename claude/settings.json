{
  "permissions": {
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable",
    "deny": [
      "Bash(sudo:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(mkfs:*)",
      "Bash(dd:*)",
      "Bash(nc:*)",
      "Bash(telnet:*)",
      "Bash(eval:*)",
      "Bash(bash -c:*)",
      "Bash(sh -c:*)",
      "Bash(zsh -c:*)",
      "Bash(python -c:*)",
      "Bash(python3 -c:*)",
      "Bash(node -e:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(**/.env*)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/*.pem)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(**/.env*)",
      "Write(~/.ssh/**)",
      "Write(~/.aws/**)",
      "Write(**/.env*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(mv:*)",
      "Bash(npm publish:*)",
      "Bash(docker:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(pkill:*)"
    ],
    "allow": [
      "Bash(npm run:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(tree:*)",
      "Bash(cp:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(echo:*)",
      "Bash(do)",
      "Bash(then)",
      "Bash(else)",
      "Bash(fi)",
      "Bash(done)",
      "Bash(for:*)",
      "Bash(npm install:*)",
      "Bash(npm exec:*)",
      "Bash(npx:*)",
      "Bash(bun:*)",
      "Bash(uv run test:*)",
      "Bash(npm ls:*)",
      "Bash(true)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:code.claude.com)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "failIfUnavailable": true,
    "filesystem": {
      "denyRead": ["~/"],
      "allowRead": ["."],
      "allowWrite": []
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "registry.npmjs.org",
        "pypi.org",
        "docs.anthropic.com",
        "code.claude.com"
      ]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "c=\"$(jq -r '.tool_input.command // empty')\"; if printf '%s' \"$c\" | grep -qE 'rm[[:space:]].*(-[a-zA-Z]*[rR]|--recursive)|dd[[:space:]]+if=|mkfs|:\\(\\)[[:space:]]*\\{'; then printf '%s' '{\"decision\":\"block\",\"reason\":\"危険な破壊的コマンドを検知したため実行を中止いたしました。別の手立てをご検討くださいませ。\"}'; elif printf '%s' \"$c\" | grep -qE '\\.env|\\.ssh/|\\.aws/|id_rsa|id_ed25519|\\.pem|credentials'; then printf '%s' '{\"decision\":\"block\",\"reason\":\"秘密情報への接触を検知したため実行を中止いたしました。\"}'; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | select(endswith(\".js\") or endswith(\".ts\") or endswith(\".jsx\") or endswith(\".tsx\"))' | xargs -r prettier --write"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | select(endswith(\".py\"))' | xargs -r uv run ruff format"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[$(date)] $USER: $(jq -r '.tool_input.command')\" >> ~/.claude/command_history.log"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -Command \"(New-Object Media.SoundPlayer 'C:\\Windows\\Media\\notify.wav').PlaySync()\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -Command \"(New-Object Media.SoundPlayer 'C:\\Windows\\Media\\Windows Message Nudge.wav').PlaySync()\" 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "PATH=\"/home/ping/.bun/bin:$PATH\" ccstatusline",
    "padding": 0,
    "refreshInterval": 10
  },
  "outputStyle": "Vampire Maid",
  "language": "japanese",
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "給仕中"
    ]
  },
  "effortLevel": "high",
  "theme": "dark"
}
