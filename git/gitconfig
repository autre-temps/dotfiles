[user]
	name = autre-temps
	email = this.png@gmail.com
[alias]
	st = status
	co = checkout
	sw = switch
	br = branch
	d = diff
	ds = diff --staged
	last = log -1 HEAD
	cm = commit -m
	amend = commit --amend --no-edit
	unstage = reset HEAD --
	undo = reset --soft HEAD~1
	stash-all = stash push --include-untracked
	logg = log --graph --abbrev-commit --decorate --all --format=format:'%C(bold blue)%h%C(reset) %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)— %an%C(reset)%C(auto)%d%C(reset)'
